# ⚠️ IMPORTANT: Never commit this file to GitHub!
# This file should be in .gitignore

# Your MetaMask Private Key (WITHOUT the 0x prefix)
# To get this: MetaMask → Account → ⋮ → Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here_without_0x

# Sepolia RPC URL from Infura or Alchemy
# Get free key at: https://infura.io or https://alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY

# Example:
# PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/abc123def456
