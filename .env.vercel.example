# Environment Variables Template

# Copy this to Vercel Dashboard → Settings → Environment Variables
# Get values from deployment.json after deploying to Sepolia

# Network Configuration
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_NETWORK_NAME=Sepolia Test Network
NEXT_PUBLIC_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY_HERE

# Contract Addresses (from deployment.json)
NEXT_PUBLIC_LENDING_POOL=0x...
NEXT_PUBLIC_FLASH_LOAN_RECEIVER=0x...

# Token Addresses (from deployment.json)
NEXT_PUBLIC_DAI_ADDRESS=0x...
NEXT_PUBLIC_USDC_ADDRESS=0x...
NEXT_PUBLIC_WETH_ADDRESS=0x...

# Optional: Enable production mode
NEXT_PUBLIC_VERCEL=1
